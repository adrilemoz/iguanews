PORT=3001

# MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/<banco>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USUARIO:SENHA@cluster0.xxxxx.mongodb.net/iguanews?retryWrites=true&w=majority&appName=Cluster0

# Cloudinary (console.cloudinary.com → Settings → API Keys)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# JWT — troque por uma string longa e aleatória em produção
JWT_SECRET=troque_por_string_segura_em_producao
JWT_EXPIRES_IN=7d

# Credenciais do admin criadas pelo: npm run seed
ADMIN_EMAIL=admin@iguanews.com
ADMIN_SENHA=admin123

# Em produção, informe a URL do seu frontend para o CORS
# FRONTEND_URL=https://seu-site.com
